{
  "patterns": {
    "all": ".*",
    "elevated": "^admin\\.new_.*"
  },

  "groups": {
    "denied": [
      { "pattern": "all", "grant": false}
    ],
    "standard": [
      { "pattern": "elevated", "grant": false},
      { "pattern": "all", "grant": true}
    ],
    "elevated": [
      { "pattern": "elevated", "grant": true}
    ]
  },

  "users" : {
    "_default": ["standard"],
    "$SYSTEM_USER": ["elevated"]
  }
}